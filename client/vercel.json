{
  "version": 2,
  "framework": "vite",
  "build": {
    "command": "npm run build"
  },
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/assets/.*",
      "dest": "/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/.*",
      "dest": "/index.html"
    }
  ]
}
