{
  "version": 2,
  "framework": "vite",
  "build": {
    "command": "npm run build"
  },
  "outputDirectory": "dist",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.+)",
      "dest": "/index.html",
      "status": 200
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
