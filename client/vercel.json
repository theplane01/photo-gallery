{
  "version": 2,
  "framework": "vite",
  "build": {
    "command": "npm run build"
  },
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/assets/.*\\.(?:js|css|woff2?|ttf|otf|eot|svg|png|jpg|jpeg|gif|webp|ico)$",
      "dest": "/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/.*\\.(?:js|css|json|woff2?|ttf|otf|eot|svg|png|jpg|jpeg|gif|webp|ico|map)$",
      "dest": "/$1"
    },
    {
      "src": "^/(?!assets/|.*\\.\\w+$)",
      "dest": "/index.html"
    }
  ]
}
